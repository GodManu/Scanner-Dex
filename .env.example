# Copia este archivo como .env y llena tus valores.
# .env está en .gitignore: nunca se sube al repo.

# ── Supabase (free tier) ──────────────────────────────────────────
# Los sacas en: Project Settings > API
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# ── PokemonTCG.io (gratis, opcional pero recomendado) ─────────────
# Sin key: 1,000 req/día. Con key gratuita: 20,000 req/día.
# La pides en: https://dev.pokemontcg.io/
EXPO_PUBLIC_POKEMONTCG_KEY=

# ─────────────────────────────────────────────────────────────────
# Lo de abajo NO va aquí: son secretos del edge function.
# Se configuran con la CLI y nunca llegan al celular del usuario:
#
#   supabase secrets set PRICE_PROVIDER=mock
#   supabase secrets set USD_TO_MXN=18.5
#
# Cuando pases a un proveedor real, agregas UNA de estas:
#   supabase secrets set PRICE_PROVIDER=ppt PPT_API_KEY=...
#   supabase secrets set PRICE_PROVIDER=pc  PRICECHARTING_TOKEN=...
